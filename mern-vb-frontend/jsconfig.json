{
    "compilerOptions": {
      "target": "esnext",
      "module": "esnext",
      "moduleResolution": "bundler",
      "ignoreDeprecations": "5.0",
      "paths": {
        "@/*": ["./src/*"]
      },
      "jsx": "react-jsx",
      "allowSyntheticDefaultImports": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
  }
  